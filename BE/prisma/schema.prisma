// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// USER MANAGEMENT
// ========================
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String
  password  String
  role      Role    @default(USER)
  
  // Profile
  avatar    String?
  level     String  @default("CỰC_CƠ_BẢN")
  levelUnlockedAt DateTime?
  levelLocked Boolean @default(false)
  
  // XP & Trophy
  totalXP   Int     @default(0)
  totalTrophy Int   @default(0)
  currentStreak Int @default(0)
  lastCheckinDate DateTime?
  
  // Relations
  vocabularyLearned Vocabulary[]
  userSavedVocabulary UserSavedVocabulary[]
  quizSessions QuizSession[]
  quizAnswers QuizAnswer[]
  writingPractices WritingPractice[]
  pronunciationAttempts PronunciationAttempt[]
  handwritingAttempts HandwritingAttempt[]
  achievements UserAchievement[]
  cameraDetections YOLODetection[] @relation("cameraDetections")
  detectionStats DetectionStats? @relation("detectionStats")
  batchJobs BatchJob[] @relation("batchJobs")
  
  // NEW: Progress tracking
  userProgress UserProgress[]
  levelTestProgress LevelTestProgress[]
  userAnswerHistory UserAnswerHistory[]
  quizHistory QuizHistory[]
  
  // Game System
  stats         UserStats?
  rank          UserRank?
  nodeProgress  UserNodeProgress[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Database Indexes for Performance
  @@index([email])
  @@index([level])
  @@index([totalXP])
  @@index([totalTrophy])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ========================
// CONTENT MANAGEMENT (ADMIN)
// ========================
model Topic {
  id      Int     @id @default(autoincrement())
  name    String
  description String?
  level   String  // CỰC_CƠ_BẢN, CƠ_BẢN, TRUNG_CẤP, NÂNG_CAO, LÃO_LUYỆN
  order   Int     @default(0)
  
  // Relations
  vocabulary Vocabulary[]
  questions Question[]
  quizQuestions QuizQuestion[]
  writingPractices WritingPractice[]
  handwritingExercises HandwritingExercise[]
  pronunciationWords PronunciationWord[]
  learningNodes LearningNode[]
  quizSessions QuizSession[]
  userProgress UserProgress[]
  userAnswerHistory UserAnswerHistory[]
  quizHistory QuizHistory[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vocabulary {
  id          Int        @id @default(autoincrement())
  korean      String
  vietnamese  String
  english     String
  romanization String?
  audioUrl    String?
  imageUrl    String?
  type        String     @default("noun")  // noun, verb, adjective, etc.
  tags        String[]   @default([])      // ["school", "place", "building"]
  level       String     @default("NEWBIE")
  topic       Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId     Int
  
  // Status
  isActive    Boolean    @default(true)
  version     Int        @default(1)
  
  // Relations
  examples    VocabExample[]
  usersLearned User[]
  pronunciationWords PronunciationWord[]
  savedByUsers UserSavedVocabulary[]
  quizQuestions QuizQuestion[]
  quizHistory QuizHistory[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Database Indexes for Performance
  @@index([topicId])
  @@index([level])
  @@index([isActive])
}

// ========================
// USER SAVED VOCABULARY (từ vựng user thu thập từ camera/quiz/writing/pronunciation)
// ========================
model UserSavedVocabulary {
  id          Int        @id @default(autoincrement())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  vocabulary  Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  vocabId     Int
  
  // Source tracking
  source      String     // "camera", "quiz", "writing", "pronunciation", "listening"
  sourceId    String?    // ID of quiz session, camera detection, etc.
  
  // Learning status
  isLearned   Boolean    @default(false)
  attempts    Int        @default(0)
  score       Float      @default(0.0)  // 0-100
  
  // For Prisma Studio CRUD
  notes       String?    // User notes/comments
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, vocabId])
  @@index([userId])
  @@index([source])
}

// ========================
// VOCABULARY EXAMPLES
// ========================
model VocabExample {
  id          Int      @id @default(autoincrement())
  korean      String
  vietnamese  String
  english     String?
  vocabulary  Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  vocabId     Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// QUIZ SYSTEM
// ========================
model Question {
  id            Int     @id @default(autoincrement())
  questionText  String
  correctAnswer String
  options       String[] // JSON array
  language_from String  // "korean" or "english"
  language_to   String  // "english" or "korean"
  difficulty    String  @default("easy") // easy, medium, hard
  topic         Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId       Int
  
  // Explanation & Translation (for learning features)
  explanation    String? // English explanation of the answer
  explanation_vi String? // Vietnamese translation of the explanation
  
  // Status
  isActive      Boolean @default(true)
  version       Int     @default(1)
  
  // Relations
  quizAnswers   QuizAnswer[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Database Indexes for Performance
  @@index([topicId])
  @@index([isActive])
}

// ========================
// QUIZ QUESTION (GENERATED FROM VOCABULARY)
// ========================
model QuizQuestion {
  id                    Int     @id @default(autoincrement())
  
  // Core question data
  vocabulary            Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  vocabularyId          Int
  
  topic                 Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId               Int
  
  // Question type
  questionType          String  @default("vocabulary") // vocabulary, phrase, context
  questionText          String  // e.g., "_____ nghĩa là gì?" or "Từ nào có nghĩa giống '[word]'?"
  correctAnswerText     String  // The correct answer display text
  
  // Correct answer (always from vocabulary meaning)
  isActive              Boolean @default(true)
  
  // Status
  usageCount            Int     @default(0)  // Tracking for analytics
  correctRate           Float   @default(0)  // 0-100: percentage of correct answers
  level                 String  // NEWBIE, BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  
  // Relations for wrong answers (store the vocabulary IDs of wrong answers)
  wrongAnswerIds        Int[]   @default([]) // Array of vocabulary IDs for wrong answers
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Database Indexes for Performance
  @@index([vocabularyId])
  @@index([topicId])
  @@index([level])
  @@index([isActive])
}

model QuizSession {
  id                Int     @id @default(autoincrement())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  topic             Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  topicId           Int?
  score             Int     @default(0)
  totalQuestions    Int
  correctAnswers    Int     @default(0)
  
  // Relations
  answers           QuizAnswer[]
  
  createdAt         DateTime @default(now())
  endedAt           DateTime?
  
  // Database Indexes for Performance
  @@index([userId])
  @@index([topicId])
}

model QuizAnswer {
  id                Int     @id @default(autoincrement())
  session           QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId         Int
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId        Int
  selectedAnswer    String
  isCorrect         Boolean
  
  createdAt         DateTime @default(now())
  
  // Database Indexes for Performance
  @@index([userId])
  @@index([sessionId])
  @@index([questionId])
}

// ========================
// WRITING PRACTICE
// ========================
model WritingPractice {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  topic       Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId     Int
  
  level       String  // NEWBIE, BEGINNER, INTERMEDIATE
  userText    String  // What user wrote
  score       Int     // 0-10
  corrected   String? // Corrected version
  feedback    String? // JSON feedback from AI
  
  createdAt   DateTime @default(now())
  
  // Database Indexes for Performance
  @@index([userId])
  @@index([topicId])
}

// ========================
// HANDWRITING PRACTICE
// ========================
model HandwritingExercise {
  id          Int     @id @default(autoincrement())
  hangulChar  String  // Single Hangul character
  strokes     Int     // Number of strokes
  level       String
  topic       Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId     Int
  
  isActive    Boolean @default(true)
  
  attempts    HandwritingAttempt[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HandwritingAttempt {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  exercise    HandwritingExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId  Int
  drawingData String  // JSON storing stroke data
  score       Int     // 0-100
  feedback    String?
  
  createdAt   DateTime @default(now())
  
  // Database Indexes for Performance
  @@index([userId])
  @@index([exerciseId])
}

// ========================
// PRONUNCIATION PRACTICE
// ========================
model PronunciationWord {
  id          Int     @id @default(autoincrement())
  vocabulary  Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  vocabId     Int
  nativeAudioUrl String
  level       String
  topic       Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId     Int
  
  attempts    PronunciationAttempt[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PronunciationAttempt {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  word        PronunciationWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId      Int
  audioUrl    String  // User's recorded audio
  transcript  String?
  accuracyScore Int?   // 0-100
  fluencyScore  Int?   // 0-100
  completenessScore Int? // 0-100
  overallScore Int?    // 0-100
  feedback    String?
  phoneticErrors String? // JSON array of phoneme errors
  
  createdAt   DateTime @default(now())
  
  // Database Indexes for Performance
  @@index([userId])
  @@index([wordId])
}

// ========================
// CAMERA DETECTION
// ========================
// ACHIEVEMENTS & GAMIFICATION
// ========================
model Achievement {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  badge       String? // URL or emoji
  criteria    String  // JSON describing unlock criteria
  
  users       UserAchievement[]
  
  createdAt   DateTime @default(now())
}

model UserAchievement {
  id            Int     @id @default(autoincrement())
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId Int
  unlockedAt    DateTime @default(now())
}

// ========================
// MONTHLY TASKS
// ========================
model MonthlyTask {
  id            Int     @id @default(autoincrement())
  name          String
  description   String
  criteria      String  // JSON describing task criteria
  reward        Int     // XP reward
  level         String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ========================
// GAME ECONOMY - USER STATS (TROPHY SYSTEM)
// ========================
model UserStats {
  id        String @id @default(uuid())
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int    @unique
  
  xp        Int @default(0)
  trophy    Int @default(0)
  
  quizCount     Int @default(0)
  writeCount    Int @default(0)
  speakCount    Int @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// RANKING SYSTEM (MATCHMAKING)
// ========================
model Rank {
  id     String @id @default(uuid())
  name   String @unique
  minXp  Int
  maxXp  Int
  order  Int
  
  userRanks UserRank[]
  
  createdAt DateTime @default(now())
}

model UserRank {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int    @unique
  
  rank   Rank @relation(fields: [rankId], references: [id])
  rankId String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================
// LEARNING MAP / PROGRESS TREE
// ========================
model LearningPath {
  id     String @id @default(uuid())
  name   String
  level  String
  
  nodes  LearningNode[]
  
  createdAt DateTime @default(now())
}

model LearningNode {
  id        String @id @default(uuid())
  title     String
  description String?
  
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  pathId    String
  
  topic     Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  topicId   Int?
  
  order     Int
  
  userProgress UserNodeProgress[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserNodeProgress {
  id        String @id @default(uuid())
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  
  node      LearningNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId    String
  
  completed Boolean @default(false)
  completedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, nodeId])
}

// ========================
// YOLO DETECTION SYSTEM
// ========================
model YOLODetection {
  id              Int     @id @default(autoincrement())
  userId          Int?
  user            User?   @relation("cameraDetections", fields: [userId], references: [id], onDelete: SetNull)
  
  // Detection info
  label           String  // Korean label (e.g., "사람", "자동차")
  confidence      Float   // 0.0 - 1.0
  bbox            String  // "[x1, y1, x2, y2]" as JSON string
  
  // Context
  sessionId       String? // Group detections from same session
  frameNumber     Int?    // Frame number in video
  videoUrl        String? // URL to recorded video
  
  // Metadata
  source          String  @default("webcam") // webcam, batch, video
  status          String  @default("processed") // raw, processed, validated
  
  // Analytics
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model DetectionSession {
  id              String  @id @default(cuid())
  userId          Int?
  
  // Session info
  startTime       DateTime @default(now())
  endTime         DateTime?
  duration        Int? // seconds
  
  // Stats
  totalFrames     Int @default(0)
  totalDetections Int @default(0)
  videoUrl        String?
  
  // Metadata
  deviceInfo      String? // JSON string with device info
  settings        String? // JSON string with detection settings
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DetectionStats {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique
  user            User    @relation("detectionStats", fields: [userId], references: [id], onDelete: Cascade)
  
  // Counters
  totalDetections Int @default(0)
  uniqueLabels    Int @default(0)
  sessionsCount   Int @default(0)
  
  // Top detections
  topLabel        String? // Most detected label
  topLabelCount   Int @default(0)
  
  // Time-based
  lastDetectionAt DateTime?
  totalTime       Int @default(0) // seconds
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BatchJob {
  id              String  @id @default(cuid())
  userId          Int?
  user            User?   @relation("batchJobs", fields: [userId], references: [id], onDelete: SetNull)
  
  // Job info
  name            String
  status          String  @default("pending") // pending, processing, completed, failed
  progress        Int @default(0) // 0-100
  
  // Input
  inputPath       String // Path to video/image directory
  inputType       String // video, image, directory
  fileCount       Int @default(0)
  
  // Output
  resultCount     Int @default(0)
  outputPath      String?
  logPath         String?
  
  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Error handling
  errorMessage    String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ========================
// LEARNING PATH PROGRESS (NEW)
// ========================
model UserProgress {
  id        String @id @default(cuid())
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  
  topic     Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId   Int
  
  skillType String // "QUIZ" | "WRITING" | "PRONUNCIATION"
  
  completed Boolean @default(false)
  score     Int?    // 0-100
  attempts  Int @default(0)
  
  completedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, topicId, skillType])
  @@index([userId])
  @@index([topicId])
}

model QuizHistory {
  id        String @id @default(cuid())
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  
  topic     Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId   Int
  
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  vocabularyId Int
  
  userAnswer    String
  correctAnswer String
  isCorrect     Boolean
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([topicId])
  @@index([vocabularyId])
}

model LevelTestProgress {
  id        String @id @default(cuid())
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  
  targetLevel String // "CỰC_CƠ_BẢN" | "CƠ_BẢN" | "TRUNG_CẤP" | "NÂNG_CAO" | "LÃO_LUYỆN"
  
  // Điều kiện (lưu trữ để tra cứu)
  requiredXP    Int
  requiredTrophy Int
  
  // Status
  isTestUnlocked Boolean @default(false)
  testStartedAt  DateTime?
  testPassed     Boolean? // null = chưa làm, true = pass, false = fail
  passedAt       DateTime?
  
  score         Int? // Score của test (0-100)
  attempts      Int @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, targetLevel])
  @@index([userId])
}

// ========================
// USER ANSWER HISTORY (LEARNING PATH HISTORY)
// ========================
model UserAnswerHistory {
  id        String @id @default(cuid())
  
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  
  topic     Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId   Int
  
  skillType String // "QUIZ" | "WRITING" | "PRONUNCIATION"
  
  question  String
  correctAnswer String
  userAnswer String
  isCorrect Boolean
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([topicId])
  @@index([skillType])
  @@index([createdAt])
}